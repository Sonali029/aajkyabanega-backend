{
  "name": "functions",
  "description": "Cloud Functions for Aaj Kya Banega",
  "scripts": {
    "build:firebase": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build:firebase && firebase emulators:start --only functions",
    "shell": "npm run build:firebase && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24.x"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@vercel/node": "^3.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
